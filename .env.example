APP_NAME=CathyChang AI
APP_BUILD_ID=2026-04-21-route-budget-v2
APP_PASSWORD=
# Optional stronger login mode. If set, each user must use their own password.
# Format: jasmine=pass1,iris=pass2,anna=pass3
APP_USERS=
MEMORY_ROOT=./data/memory
CORS_ALLOW_ORIGINS=*
DEBUG=false

AGENT_PROVIDER_ORDER=cerebras,mistral,openrouter,cloudflare,groq,aws,fireworks,gemini
AGENT_PROVIDER_DISABLE=
MAX_OUTPUT_TOKENS=4096
REQUEST_TIMEOUT_SEC=120
CHAT_PROVIDER_TIMEOUT_SEC=18
OPENROUTER_TIMEOUT_SEC=18
MAX_PROMPT_TOKENS=9000
LIGHT_PROVIDER_MAX_PROMPT_TOKENS=1000
GROQ_MAX_OUTPUT_TOKENS=1536
CLOUDFLARE_MAX_OUTPUT_TOKENS=1536
FAST_MODE_MAX_TOKENS=768
STABLE_MODE_MAX_TOKENS=2048
DEEP_MODE_MAX_TOKENS=4096
FAST_MODE_PROVIDER_ORDER=cerebras,mistral,openrouter,groq,cloudflare,aws,fireworks,gemini
STABLE_MODE_PROVIDER_ORDER=cerebras,mistral,openrouter,cloudflare,groq,aws,fireworks,gemini
DEEP_MODE_PROVIDER_ORDER=cerebras,mistral,openrouter,aws,cloudflare,groq,fireworks,gemini
# Mobile Safari is handled in static/app.js:
# - fast/stable disable auto-continue
# - mobile fast/stable prefer openrouter / fireworks
# - gemini is intentionally placed last
MAX_USER_MESSAGE_CHARS=20000
MAX_HISTORY_TURN_CHARS=800
MAX_SUMMARY_CHARS=1200
MAX_GLOBAL_MEMORY_CHARS=1600
LIGHT_SUMMARY_CHARS=480
LIGHT_GLOBAL_MEMORY_CHARS=320
LIGHT_USER_MESSAGE_CHARS=1600
LIGHT_HISTORY_TURNS=0
AUTO_CONTINUE_ENABLED=true
AUTO_CONTINUE_MAX_ROUNDS=2
AUTO_CONTINUE_TAIL_CHARS=1200
FAST_MODE_ROUTE_TIMEOUT_SEC=35
STABLE_MODE_ROUTE_TIMEOUT_SEC=55
DEEP_MODE_ROUTE_TIMEOUT_SEC=75
FAST_MODE_CONTINUE_ROUNDS=0
STABLE_MODE_CONTINUE_ROUNDS=1
DEEP_MODE_CONTINUE_ROUNDS=2
FAST_MODE_PROVIDER_TIMEOUT_SEC=10
STABLE_MODE_PROVIDER_TIMEOUT_SEC=14
DEEP_MODE_PROVIDER_TIMEOUT_SEC=20

CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama3.1-8b

MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_HTTP_REFERER=

FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/minimax-m2p7
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

CF_API_TOKEN=
CF_ACCOUNT_ID=
CF_MODEL=@cf/meta/llama-3.1-8b-instruct

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
