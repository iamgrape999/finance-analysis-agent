APP_NAME=CathyChang AI
APP_PASSWORD=
# Optional stronger login mode. If set, each user must use their own password.
# Format: jasmine=pass1,iris=pass2,anna=pass3
APP_USERS=
MEMORY_ROOT=./data/memory
CORS_ALLOW_ORIGINS=*
DEBUG=false

AGENT_PROVIDER_ORDER=openrouter,fireworks,gemini,cloudflare,groq,aws
AGENT_PROVIDER_DISABLE=
MAX_OUTPUT_TOKENS=4096
REQUEST_TIMEOUT_SEC=120
MAX_PROMPT_TOKENS=9000
MIN_CHAT_MAX_TOKENS=3000
MAX_USER_MESSAGE_CHARS=20000
MAX_HISTORY_TURN_CHARS=800
MAX_SUMMARY_CHARS=1200
MAX_GLOBAL_MEMORY_CHARS=1600

OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_HTTP_REFERER=

FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/minimax-m2p7
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

CF_API_TOKEN=
CF_ACCOUNT_ID=
CF_MODEL=@cf/meta/llama-3.1-8b-instruct

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BEDROCK_MODEL=anthropic.claude-3-haiku-20240307-v1:0
