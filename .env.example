MAX_SUMMARY_CHARS=1200
MAX_GLOBAL_MEMORY_CHARS=1600
LIGHT_SUMMARY_CHARS=480
LIGHT_GLOBAL_MEMORY_CHARS=320
LIGHT_USER_MESSAGE_CHARS=1600
