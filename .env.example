APP_NAME=CathyChang AI
APP_BUILD_ID=2026-04-21-route-budget-v2
APP_PASSWORD=
# Optional stronger login mode. If set, each user must use their own password.
# Format: jasmine=pass1,iris=pass2,anna=pass3
APP_USERS=
MEMORY_ROOT=./data/memory
CORS_ALLOW_ORIGINS=*
DEBUG=false
WEB_SEARCH_ENABLED=true
TAVILY_API_KEY=
SERPER_API_KEY=
WEB_SEARCH_MAX_RESULTS=3
WEB_SEARCH_TIMEOUT_SEC=8
WEB_SEARCH_MAX_CONTEXT_CHARS=2400
LIGHT_WEB_SEARCH_MAX_CONTEXT_CHARS=900
WEB_SEARCH_SEARCH_DEPTH=basic
WEB_SEARCH_TOPIC=general
WEB_SEARCH_PROVIDER_ORDER=tavily,serper
SERPER_GL=tw
SERPER_HL=zh-tw
# Optional ASCII-only extra keywords to append to the built-in universal classifier
WEB_SEARCH_EXTRA_KEYWORDS=live score,tariff,earnings,date

AGENT_PROVIDER_ORDER=cerebras,groq,mistral,gemini,openrouter,cloudflare,fireworks,aws,nvidia
AGENT_PROVIDER_DISABLE=
MAX_OUTPUT_TOKENS=4096
REQUEST_TIMEOUT_SEC=120
# Per-provider read timeouts (seconds)
DEFAULT_PROVIDER_TIMEOUT_SEC=18
CEREBRAS_TIMEOUT_SEC=5
GROQ_TIMEOUT_SEC=8
GEMINI_TIMEOUT_SEC=25
MISTRAL_TIMEOUT_SEC=6
OPENROUTER_TIMEOUT_SEC=25
CLOUDFLARE_TIMEOUT_SEC=10
FIREWORKS_TIMEOUT_SEC=15
NVIDIA_TIMEOUT_SEC=30
AWS_TIMEOUT_SEC=18
MAX_PROMPT_TOKENS=9000
LIGHT_PROVIDER_MAX_PROMPT_TOKENS=1000
GROQ_MAX_OUTPUT_TOKENS=1536
CLOUDFLARE_MAX_OUTPUT_TOKENS=1536
FAST_MODE_MAX_TOKENS=768
STABLE_MODE_MAX_TOKENS=2048
DEEP_MODE_MAX_TOKENS=4096
FAST_MODE_PROVIDER_ORDER=cerebras,groq,mistral,gemini,openrouter,cloudflare,fireworks,aws,nvidia
STABLE_MODE_PROVIDER_ORDER=cerebras,groq,mistral,gemini,openrouter,cloudflare,fireworks,aws,nvidia
DEEP_MODE_PROVIDER_ORDER=cerebras,groq,mistral,gemini,openrouter,cloudflare,fireworks,aws,nvidia
# Mobile Safari is handled in static/app.js:
# - fast/stable disable auto-continue
# - mobile fast/stable prefer openrouter / fireworks
# - gemini is intentionally placed last
MAX_USER_MESSAGE_CHARS=20000
MAX_HISTORY_TURN_CHARS=800
MAX_SUMMARY_CHARS=1200
MAX_GLOBAL_MEMORY_CHARS=1600
LIGHT_SUMMARY_CHARS=480
LIGHT_GLOBAL_MEMORY_CHARS=320
LIGHT_USER_MESSAGE_CHARS=1600
LIGHT_HISTORY_TURNS=0
AUTO_CONTINUE_ENABLED=true
AUTO_CONTINUE_MAX_ROUNDS=2
AUTO_CONTINUE_TAIL_CHARS=1200
FAST_MODE_ROUTE_TIMEOUT_SEC=35
STABLE_MODE_ROUTE_TIMEOUT_SEC=55
DEEP_MODE_ROUTE_TIMEOUT_SEC=75
FAST_MODE_CONTINUE_ROUNDS=0
STABLE_MODE_CONTINUE_ROUNDS=1
DEEP_MODE_CONTINUE_ROUNDS=2

NVIDIA_API_KEY=
